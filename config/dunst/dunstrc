[global]
monitor = 0
follow = mouse
geometry = "0x60-20+22"
indicate_hidden = yes
shrink = yes
separator_height = 0
padding = 5
horizontal_padding = 5
frame_width = 0
sort = no
idle_threshold = 120
font = JetBrains Mono 10
line_height = 4
markup = full
format = %s\n%b
alignment = left
show_age_threshold = 60
word_wrap = yes
ignore_newline = no
stack_duplicates = false
hide_duplicate_count = no
show_indicators = no
icon_position = left
icon_path = /usr/share/icons/Papirus/
max_icon_size = 50
sticky_history = yes
history_length = 20
browser = /usr/bin/firefox -new-tab
always_run_script = true
title = Dunst
class = Dunst


[shortcuts]
close = ctrl+space
close_all = ctrl+shift+space
history = ctrl+grave
context = ctrl+shift+period

[urgency_low]
timeout = 1
foreground = "#7f3ea3"
background = "#282c34"
#frame_color = "#8bc34a"

[urgency_normal]
timeout = 4
foreground = "#7f3ea3"
background = "#282c34"
#frame_color = "#ba68c8"

[urgency_critical]
timeout = 0
foreground = "#7f3ea3"
background = "#f76868"

#frame_color = "#ff7043"
